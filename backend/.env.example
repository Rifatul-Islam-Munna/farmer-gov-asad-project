NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000
ACCESS_TOKEN=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret
ACCESS_TOKEN_EXPIRES_SECONDS=864000
REFRESH_TOKEN_EXPIRES_SECONDS=2592000
ADMIN_EMAIL=
ADMIN_PASSWORD=

# PostgreSQL: either DATABASE_URL or the DB_* values below
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=agrivision
DB_SSL=false
DB_SYNCHRONIZE=true
DB_MIGRATIONS_RUN=false
DB_LOGGING=false
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000

# MinIO / S3-compatible storage
MINIO_URL=http://127.0.0.1:9000
MINIO_PUBLIC_URL=http://127.0.0.1:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=agrivision
MINIO_REGION=us-east-1
MINIO_PUBLIC_BUCKET=false

# Redis / BullMQ
REDIS_URL=redis://127.0.0.1:6379

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_SAMPLE_COLLECTION=agri_image_samples_v1
QDRANT_PROFILE_COLLECTION=agri_image_profiles_v1

# Encrypts provider secrets saved from the Next.js admin panel.
# Keep this only on the backend and never expose it to Next.js or Flutter.
CONFIG_ENCRYPTION_KEY=replace-with-a-long-random-secret

# OTP and password reset
OTP_PROVIDER_URL=
OTP_PROVIDER_API_KEY=
OTP_EXPIRES_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_DAILY_LIMIT=10
OTP_EXPOSE_CODE_IN_DEVELOPMENT=true

# BullMQ feature-worker concurrency
WORKER_AI_CONCURRENCY=2
WORKER_NOTIFICATIONS_CONCURRENCY=4
WORKER_MEDIA_CONCURRENCY=2
WORKER_REPORTS_CONCURRENCY=1

# Audited support mode (disabled by default)
SUPPORT_IMPERSONATION_ENABLED=false

# Marketplace payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Marketplace cache
REDIS_URL=redis://localhost:6379

# Marketplace AI provider adapters
MARKETPLACE_TEXT_PROVIDER_URL=
MARKETPLACE_TEXT_PROVIDER_API_KEY=
MARKETPLACE_TEXT_PROVIDER_MODEL=
IMAGE_EDIT_PROVIDER_URL=
IMAGE_EDIT_PROVIDER_API_KEY=

# Short-lived signed mobile invoice links
INVOICE_SIGNING_SECRET=
PUBLIC_API_URL=http://localhost:4000
