NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000
ACCESS_TOKEN=replace-with-a-long-random-secret
ADMIN_EMAIL=
ADMIN_PASSWORD=

# PostgreSQL: either DATABASE_URL or the DB_* values below
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=agrivision
DB_SSL=false
DB_SYNCHRONIZE=true
DB_MIGRATIONS_RUN=false
DB_LOGGING=false
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000

# MinIO / S3-compatible storage
MINIO_URL=http://127.0.0.1:9000
MINIO_PUBLIC_URL=http://127.0.0.1:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=agrivision
MINIO_REGION=us-east-1
MINIO_PUBLIC_BUCKET=false

# Redis / BullMQ
REDIS_URL=redis://127.0.0.1:6379

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_SAMPLE_COLLECTION=agri_image_samples_v1
QDRANT_PROFILE_COLLECTION=agri_image_profiles_v1

# Encrypts provider secrets saved from the Next.js admin panel.
# Keep this only on the backend and never expose it to Next.js or Flutter.
CONFIG_ENCRYPTION_KEY=replace-with-a-long-random-secret
